# 签名配置示例 - 复制为 keystore.properties 并填入真实信息
# 注意：keystore.properties 不应提交到 Git（已在 .gitignore 中）
#
# 生成 keystore 的命令：
#   keytool -genkey -v -keystore release.keystore -alias game4399 \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# CI 自动构建时（GitHub Actions）：
#   - 不配置 Secrets → 使用 Android SDK 自带的 debug.keystore
#   - 配置 Secrets SIGNING_KEY_BASE64 等 → 使用自有签名
#
# storeFile 路径相对于 app/ 目录

storeFile=release.keystore
storePassword=你的存储密码
keyAlias=game4399
keyPassword=你的密钥密码
